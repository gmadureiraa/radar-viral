# ── Database (compartilhado com radar-viral v1) ──────────────────────
DATABASE_URL=postgresql://...

# ── Neon Auth (Better Auth) ──────────────────────────────────────────
NEXT_PUBLIC_NEON_AUTH_URL=https://....neonauth....aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://....neonauth....aws.neon.tech/neondb/auth/.well-known/jwks.json

# ── Pipelines ────────────────────────────────────────────────────────
APIFY_API_KEY=
GEMINI_API_KEY=

# ── Cron protection ──────────────────────────────────────────────────
# Bearer/?token validação pra GET /api/cron/* manual. Vercel cron envia
# header `x-vercel-cron` automaticamente, então funciona sem secret em
# schedules. Secret só é exigido em chamadas externas.
CRON_SECRET=

# ── Cron feature flag (default desativado) ───────────────────────────
# Default: cron skipa silenciosamente. v1 legacy ainda popula DB. Quando
# v2 estiver pronto pra assumir os crons, setar = "true" e desligar v1.
RADAR_V2_CRON_ENABLED=false

# ── Site URL (pra metadataBase + OAuth callbacks) ────────────────────
NEXT_PUBLIC_SITE_URL=https://radar.kaleidos.com.br
