{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    { "path": "/api/cron/refresh", "schedule": "0 9 * * *" },
    { "path": "/api/cron/brief", "schedule": "0 10 * * *" },
    { "path": "/api/cron/scrape-tiktok", "schedule": "0 11 * * *" }
  ],
  "functions": {
    "app/api/cron/refresh/route.ts": { "maxDuration": 300 },
    "app/api/cron/brief/route.ts": { "maxDuration": 300 },
    "app/api/cron/scrape-tiktok/route.ts": { "maxDuration": 300 }
  }
}
